{
  "name": "garu-ko",
  "version": "0.2.9",
  "description": "Ultra-lightweight Korean morphological analyzer for the web (1.7MB model, WASM 93KB, F1 95.3%)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "pkg",
    "models",
    "README.md"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/garu-wasm --target web --out-dir ../../js/pkg",
    "build:js": "tsc",
    "build": "npm run build:wasm && npm run build:js",
    "test": "vitest run"
  },
  "keywords": [
    "korean",
    "morphological-analysis",
    "nlp",
    "wasm",
    "lightweight",
    "browser"
  ],
  "author": "cyj <dydwls140@naver.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ongjin/garu.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4",
    "vitest": "^2.0"
  }
}
